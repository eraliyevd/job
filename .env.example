# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/ishbor?retryWrites=true&w=majority

# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Generate each with: openssl rand -base64 64
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64
JWT_REFRESH_SECRET=CHANGE_ME_different_secret_generate_with_openssl_rand_base64_64

# ─── Admin Panel ─────────────────────────────────────────────────────────────
# Hidden route slug — set to something unguessable (e.g. random hex string)
# Access admin at: https://your-domain.com/${ADMIN_SLUG}
# NEVER commit the real value to git.
ADMIN_SLUG=cp
NEXT_PUBLIC_ADMIN_SLUG=cp

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-app.railway.app
